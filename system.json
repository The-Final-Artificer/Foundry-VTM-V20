{
  "id": "vtm-v20",
  "title": "Vampire: The Masquerade V20",
  "description": "A clean, modern system for Vampire: The Masquerade 20th Anniversary Edition.",
  "version": "0.1.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [{ "name": "The Final Artificer" }],
  "esmodules": ["vtm-v20.mjs"],
  "styles": ["styles/vtm-v20.css"],
  "languages": [{
    "lang": "en",
    "name": "English",
    "path": "lang/en.json"
  }],
  "packs": [
    {
      "name": "disciplines",
      "label": "Disciplines",
      "system": "vtm-v20",
      "path": "packs/disciplines",
      "type": "Item",
      "banner": "systems/vtm-v20/Compendium header images/Disciplines header.png"
    },
    {
      "name": "backgrounds",
      "label": "Backgrounds",
      "system": "vtm-v20",
      "path": "packs/backgrounds",
      "type": "Item",
      "banner": "systems/vtm-v20/Compendium header images/Backgrounds Header.png"
    },
    {
      "name": "weapons",
      "label": "Weapons",
      "system": "vtm-v20",
      "path": "packs/weapons",
      "type": "Item",
      "banner": "systems/vtm-v20/Compendium header images/Weapons Header.png"
    },
    {
      "name": "armor",
      "label": "Attire",
      "system": "vtm-v20",
      "path": "packs/armor",
      "type": "Item",
      "banner": "systems/vtm-v20/Compendium header images/Armor header.png"
    },
    {
      "name": "merits",
      "label": "Merits",
      "system": "vtm-v20",
      "path": "packs/merits",
      "type": "Item",
      "banner": "systems/vtm-v20/Compendium header images/Merits Header.png"
    },
    {
      "name": "flaws",
      "label": "Flaws",
      "system": "vtm-v20",
      "path": "packs/flaws",
      "type": "Item",
      "banner": "systems/vtm-v20/Compendium header images/Flaws Header.png"
    }
  ],
  "initiative": "1d10 + @attributes.dexterity + @attributes.wits",
  "primaryTokenAttribute": "health",
  "secondaryTokenAttribute": "blood",
  "socket": true
}
