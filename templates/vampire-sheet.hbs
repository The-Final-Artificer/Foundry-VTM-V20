{{#if chargenActive}}
{{> "systems/vtm-v20/templates/chargen.hbs"}}
{{else}}
<div class="sheet-inner">

{{!-- TOP: portrait + header/status side by side --}}
<div class="sheet-top">
  <div class="portrait-panel">
    <div class="portrait">
      <img src="{{actor.img}}" data-edit="img" title="{{actor.name}}" draggable="false" />
      <button type="button" class="portrait-edit" title="Change portrait"><i class="fas fa-image"></i></button>
    </div>
  </div>
  <div class="sheet-top-right">
    <header class="sheet-header">
      <div class="header-fields">
    <div class="name-row">
      <h1 class="char-name">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Name" />
      </h1>
      {{#if isGM}}
      <a class="sheet-lock" title="{{#if lockState}}Unlock Sheet{{else}}Lock Sheet{{/if}}">
        <i class="fas {{#if lockState}}fa-lock{{else}}fa-lock-open{{/if}}"></i>
      </a>
      {{/if}}
    </div>
    <div class="header-row">
      {{#if isVampire}}
      <div class="field">
        <label>Clan</label>
        <select name="system.clan">
          <option value=""></option>
          {{#each config.clans}}
          <option value="{{this}}" {{#if (eq this ../system.clan)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="field">
        <label>Generation</label>
        <input type="number" name="system.generation" value="{{system.generation}}" min="3" max="15" />
      </div>
      {{/if}}
      <div class="field">
        <label>Nature</label>
        <select name="system.nature">
          <option value=""></option>
          {{#each config.natures}}
          <option value="{{this}}" {{#if (eq this ../system.nature)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="field">
        <label>Demeanor</label>
        <select name="system.demeanor">
          <option value=""></option>
          {{#each config.natures}}
          <option value="{{this}}" {{#if (eq this ../system.demeanor)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    <div class="header-row">
      {{#if isVampire}}
      <div class="field">
        <label>Sire</label>
        <input type="text" name="system.sire" value="{{system.sire}}" />
      </div>
      {{/if}}
      <div class="field">
        <label>Concept</label>
        <input type="text" name="system.concept" value="{{system.concept}}" />
      </div>
      <div class="field">
        <label>Player</label>
        <input type="text" name="system.player" value="{{system.player}}" />
      </div>
      <div class="field">
        <label>Chronicle</label>
        <input type="text" name="system.chronicle" value="{{system.chronicle}}" />
      </div>
    </div>
  </div>
</header>

{{!-- STATUS BAR --}}
<div class="status-bar">
  <div class="status-block health-mini">
    <label><i class="fas fa-heart"></i> Health</label>
    <div class="health-pips">
      {{#each healthTrack}}
      {{#unless this.infoOnly}}
      <span class="health-pip {{this.cssClass}}" title="{{this.label}}">{{this.damageLabel}}</span>
      {{/unless}}
      {{/each}}
    </div>
  </div>
  <div class="status-block soak-mini">
    <button type="button" class="soak-btn" title="Soak {{soakPool}} ({{soakLabel}})">
      <i class="fas fa-shield-alt"></i>
    </button>
  </div>
  {{#if isVampire}}
  <div class="status-block blood-mini">
    <label><i class="fas fa-tint"></i> Blood {{system.blood.value}}/{{system.blood.max}}</label>
    <div class="blood-bar-wrap">
      <div class="blood-bar" style="width: {{bloodPct}}%"></div>
    </div>
    <div class="blood-btns">
      <button type="button" class="blood-spend"><i class="fas fa-minus"></i></button>
      <button type="button" class="blood-gain"><i class="fas fa-plus"></i></button>
    </div>
  </div>
  {{/if}}
  <div class="status-block wp-mini">
    <label><i class="fas fa-brain"></i> WP {{system.willpower.value}}/{{system.willpower.max}}</label>
    <div class="wp-track">
      {{{vtmSquares system.willpower.value system.willpower.max}}}
    </div>
  </div>
  <div class="status-block move-mini">
    <label><i class="fas fa-running"></i> {{curMove.label}}</label>
    <span class="move-val">{{curMove.value}} yds</span>
  </div>
</div>
  </div>{{!-- .sheet-top-right --}}
</div>{{!-- .sheet-top --}}

{{!-- TABS --}}
<nav class="sheet-tabs" data-group="primary">
  <a class="item" data-tab="stats"><i class="fas fa-chart-bar"></i> Stats</a>
  {{#if isVampire}}<a class="item" data-tab="powers"><i class="fas fa-fire"></i> Advantages</a>{{/if}}
  <a class="item" data-tab="status"><i class="fas fa-heartbeat"></i> Status</a>
  <a class="item" data-tab="combat"><i class="fas fa-fist-raised"></i> Combat</a>
  <a class="item" data-tab="inventory"><i class="fas fa-suitcase"></i> Inventory</a>
  <a class="item" data-tab="bio"><i class="fas fa-book"></i> Bio</a>
  <div class="money-section">
    <i class="fas fa-dollar-sign money-sign"></i>
    <span class="money-amount">{{moneyDisplay}}</span>
    {{#if isGM}}
    <a class="money-edit" title="Edit Money"><i class="fas fa-pencil-alt"></i></a>
    {{/if}}
  </div>
</nav>

{{!-- BODY --}}
<section class="sheet-body">

  {{!-- STATS --}}
  <div class="tab stats" data-group="primary" data-tab="stats">
    <div class="section-block">
      <h2>Attributes</h2>
      <div class="trait-columns">
        {{#each attrGroups}}
        <div class="trait-column">
          <h3>{{this.label}}</h3>
          {{#each this.traits}}
          <div class="trait-row">
            <span class="trait-label rollable" data-roll="{{this.rollKey}}" data-label="{{this.label}}">{{this.label}}</span>
            <div class="dot-row" data-path="{{this.path}}">
              {{{vtmDots this.value 5}}}
            </div>
          </div>
          {{/each}}
        </div>
        {{/each}}
      </div>
    </div>

    <div class="section-block">
      <h2>Abilities</h2>
      <div class="trait-columns">
        {{#each abilGroups}}
        <div class="trait-column">
          <h3>{{this.label}}</h3>
          {{#each this.traits}}
          <div class="trait-row">
            <span class="trait-label rollable" data-roll="{{this.rollKey}}" data-label="{{this.label}}">{{this.label}}</span>
            <div class="dot-row" data-path="{{this.path}}">
              {{{vtmDots this.value 5}}}
            </div>
          </div>
          {{/each}}
        </div>
        {{/each}}
      </div>
    </div>
  </div>

  {{!-- POWERS --}}
  {{#if isVampire}}
  <div class="tab powers" data-group="primary" data-tab="powers">
    <div class="trait-columns">
      <div class="trait-column">
        <h3>Disciplines</h3>
        <div class="item-list">
          {{#each disciplines}}
          <div class="item" data-item-id="{{this._id}}">
            <img class="item-img" src="{{this.img}}" width="25" height="25" />
            <span class="item-name item-open">{{this.name}}</span>
            <div class="dot-row item-dots" data-item-id="{{this._id}}" data-field="system.level">
              {{{vtmDots this.system.level 5}}}
            </div>
            <div class="item-controls">
              <a class="item-edit" title="Rename"><i class="fas fa-edit"></i></a>
              <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
      <div class="trait-column">
        <h3>Backgrounds</h3>
        <div class="item-list">
          {{#each backgrounds}}
          <div class="bg-entry" data-item-id="{{this._id}}">
            <div class="item" data-item-id="{{this._id}}">
              <span class="item-name item-open">{{this.name}}</span>
              <div class="dot-row item-dots" data-item-id="{{this._id}}" data-field="system.rating">
                {{{vtmDots this.system.rating 5}}}
              </div>
              <div class="item-controls">
                <a class="item-edit" title="Rename"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            <textarea class="bg-notes" data-item-id="{{this._id}}" placeholder="Notes..."{{#if ../sheetLocked}} disabled{{/if}}>{{this.system.notes}}</textarea>
          </div>
          {{/each}}
        </div>
      </div>
      <div class="trait-column">
        <h3>Virtues</h3>
        <div class="trait-row">
          <span class="trait-label rollable" data-roll="virtues.conscience" data-label="{{virtueLabels.conscience}}">{{virtueLabels.conscience}}</span>
          <div class="dot-row" data-path="system.virtues.conscience">
            {{{vtmDots system.virtues.conscience 5}}}
          </div>
        </div>
        <div class="trait-row">
          <span class="trait-label rollable" data-roll="virtues.selfControl" data-label="{{virtueLabels.selfControl}}">{{virtueLabels.selfControl}}</span>
          <div class="dot-row" data-path="system.virtues.selfControl">
            {{{vtmDots system.virtues.selfControl 5}}}
          </div>
        </div>
        <div class="trait-row">
          <span class="trait-label rollable" data-roll="virtues.courage" data-label="{{virtueLabels.courage}}">{{virtueLabels.courage}}</span>
          <div class="dot-row" data-path="system.virtues.courage">
            {{{vtmDots system.virtues.courage 5}}}
          </div>
        </div>

        <h3>Merits</h3>
        <div class="item-list compact">
          {{#each merits}}
          <div class="item" data-item-id="{{this._id}}">
            <span class="item-name item-open">{{this.name}}</span>
            <span class="item-cost">({{this.system.cost}}pt)</span>
            <div class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          {{/each}}
        </div>

        <h3>Flaws</h3>
        <div class="item-list compact">
          {{#each flaws}}
          <div class="item" data-item-id="{{this._id}}">
            <span class="item-name item-open">{{this.name}}</span>
            <span class="item-cost">({{abs this.system.cost}}pt)</span>
            <div class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </div>
  </div>
  {{/if}}

  {{!-- STATUS --}}
  <div class="tab status" data-group="primary" data-tab="status">
    <div class="status-columns">
      <div class="status-column">
        <div class="section-block">
          <h3>Health</h3>
          <div class="health-track">
            {{#each healthTrack}}
            <div class="health-row {{#if this.infoOnly}}info-only{{/if}}">
              <span class="health-label">{{this.label}}</span>
              <span class="health-penalty">
                {{#if (eq this.penalty null)}}---{{else}}{{this.penalty}}{{/if}}
              </span>
              {{#if this.infoOnly}}
              <div class="health-placeholder"></div>
              {{else}}
              <div class="health-box {{this.cssClass}}" data-level="{{this.key}}">
                {{this.damageLabel}}
              </div>
              {{/if}}
              <span class="health-desc">{{this.desc}}</span>
            </div>
            {{/each}}
          </div>
          <div class="health-actions">
            <button type="button" class="soak-btn" title="Click to roll soak">
              <i class="fas fa-shield-alt"></i> Soak {{soakPool}} ({{soakLabel}})
            </button>
            {{#if isVampire}}
            <button type="button" class="heal-btn" title="Spend blood to heal damage">
              <i class="fas fa-tint"></i> Heal
            </button>
            {{/if}}
            {{#if woundPenalty}}
            <span class="wound-penalty">Wound Penalty: {{woundPenalty}}</span>
            {{/if}}
          </div>
        </div>

        <div class="section-block">
          <h3>Movement <span class="movement-unit">(yards/turn)</span></h3>
          <div class="movement-grid">
            <div class="move-row {{#if (eq curMove.label 'Walk')}}active{{/if}}"><i class="fas fa-walking"></i><span class="move-label">Walk</span><span class="move-value">{{movement.walk}}</span></div>
            <div class="move-row {{#if (eq curMove.label 'Jog')}}active{{/if}}"><i class="fas fa-running"></i><span class="move-label">Jog</span><span class="move-value">{{movement.jog}}</span></div>
            <div class="move-row {{#if (eq curMove.label 'Run')}}active{{/if}}"><i class="fas fa-bolt"></i><span class="move-label">Run</span><span class="move-value">{{movement.run}}</span></div>
            <div class="move-row {{#if (eq curMove.label 'Hobble')}}active{{/if}}"><i class="fas fa-crutch"></i><span class="move-label">Hobble</span><span class="move-value">{{movement.hobble}}</span></div>
            <div class="move-row {{#if (eq curMove.label 'Crawl')}}active{{/if}}"><i class="fas fa-hand-paper"></i><span class="move-label">Crawl</span><span class="move-value">{{movement.crawl}}</span></div>
          </div>
          <button type="button" class="jump-btn" title="Roll a jump (difficulty 3)"><i class="fas fa-angle-double-up"></i> Jump</button>
        </div>
      </div>

      <div class="status-column">
        {{#if isVampire}}
        <div class="section-block">
          <h3>Generation Info</h3>
          <div class="gen-info">
            <span>Max trait rating: <span class="gen-val">{{traitMax}}</span></span>
            <span class="gen-sep">·</span>
            <span>Blood per turn: <span class="gen-val">{{bloodPerTurn}}</span></span>
          </div>
        </div>
        {{/if}}

        <div class="section-block">
          <h3>Willpower</h3>
          <div class="wp-detail">
            <label>Permanent</label>
            <div class="wp-perm-row">
              <div class="dot-row" data-path="system.willpower.max">
                {{{vtmDots system.willpower.max 10}}}
              </div>
              <span class="wp-adjective">{{wpAdjective}}</span>
            </div>
            <label>Temporary</label>
            <div class="wp-temp-row">
              <div class="wp-track" data-path="system.willpower.value">
                {{{vtmSquares system.willpower.value system.willpower.max}}}
              </div>
              <button type="button" class="wp-roll rollable" data-roll="willpower" data-label="Willpower" title="Roll Willpower">
                <i class="fas fa-dice-d20"></i> Roll
              </button>
            </div>
          </div>
        </div>

        <div class="section-block path-block">
          <h3 data-tip="humanity">
            {{#if isVampire}}
            <select name="system.pathName" class="path-select" {{#if sheetLocked}}style="pointer-events:none"{{/if}}>
              {{#each pathChoices}}
              <option value="{{this}}" {{#if (eq this ../system.pathName)}}selected{{/if}}>{{this}}</option>
              {{/each}}
            </select>
            {{else}}
            Humanity
            {{/if}}
          </h3>
          <div class="dot-row" data-path="system.humanity">
            {{{vtmDots system.humanity 10}}}
          </div>
          <div class="bearing-info">
            <span class="bearing-type">Bearing: {{bearingName}}</span>
            {{#if bearingLabel}}
            <span class="bearing-label">({{bearingLabel}})</span>
            {{/if}}
            {{#if bearingMod}}
            <span class="bearing-mod">{{bearingMod}}</span>
            {{else}}
            {{#if (eq system.humanity 0)}}
            <span class="bearing-lost">Character lost</span>
            {{/if}}
            {{/if}}
          </div>
        </div>

        <div class="section-block">
          <h3>Experience</h3>
          <div class="exp-fields">
            <div class="field">
              <label>Unspent</label>
              <input type="number" name="system.experience.current" value="{{system.experience.current}}" min="0" />
            </div>
            <div class="field">
              <label>Total</label>
              <input type="number" name="system.experience.total" value="{{system.experience.total}}" min="0" />
            </div>
          </div>
        </div>

        <div class="section-block">
          <h3>Situational Checks</h3>
          <div class="sit-checks">
            <button type="button" class="sit-check-btn fall-btn"><i class="fas fa-arrow-down"></i> Falling</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  {{!-- BIO --}}
  <div class="tab bio" data-group="primary" data-tab="bio">
    <div class="bio-toolbar">
      <select class="bio-format-block" title="Block Format">
        <option value="" disabled selected>Format</option>
        <option value="<p>">Paragraph</option>
        <option value="<h1>">Heading 1</option>
        <option value="<h2>">Heading 2</option>
        <option value="<h3>">Heading 3</option>
        <option value="<blockquote>">Quote</option>
        <option value="<pre>">Code</option>
      </select>
      <span class="bio-fmt-sep"></span>
      <select class="bio-font-size" title="Font Size">
        <option value="1">10px</option>
        <option value="2">13px</option>
        <option value="3" selected>16px</option>
        <option value="4">18px</option>
        <option value="5">24px</option>
        <option value="6">32px</option>
        <option value="7">48px</option>
      </select>
      <span class="bio-fmt-sep"></span>
      <button type="button" class="bio-fmt" data-cmd="bold" title="Bold"><i class="fas fa-bold"></i></button>
      <button type="button" class="bio-fmt" data-cmd="italic" title="Italic"><i class="fas fa-italic"></i></button>
      <button type="button" class="bio-fmt" data-cmd="underline" title="Underline"><i class="fas fa-underline"></i></button>
      <button type="button" class="bio-fmt" data-cmd="strikethrough" title="Strikethrough"><i class="fas fa-strikethrough"></i></button>
      <span class="bio-fmt-sep"></span>
      <button type="button" class="bio-fmt" data-cmd="justifyLeft" title="Align Left"><i class="fas fa-align-left"></i></button>
      <button type="button" class="bio-fmt" data-cmd="justifyCenter" title="Align Center"><i class="fas fa-align-center"></i></button>
      <button type="button" class="bio-fmt" data-cmd="justifyRight" title="Align Right"><i class="fas fa-align-right"></i></button>
      <span class="bio-fmt-sep"></span>
      <button type="button" class="bio-fmt" data-cmd="insertUnorderedList" title="Bullet List"><i class="fas fa-list-ul"></i></button>
      <button type="button" class="bio-fmt" data-cmd="insertOrderedList" title="Numbered List"><i class="fas fa-list-ol"></i></button>
      <button type="button" class="bio-fmt" data-cmd="outdent" title="Decrease Indent"><i class="fas fa-outdent"></i></button>
      <button type="button" class="bio-fmt" data-cmd="indent" title="Increase Indent"><i class="fas fa-indent"></i></button>
      <span class="bio-fmt-sep"></span>
      <button type="button" class="bio-fmt" data-cmd="removeFormat" title="Clear Formatting"><i class="fas fa-eraser"></i></button>
    </div>
    <div class="bio-section" data-bio-field="bio">
      <h3>Description</h3>
      <div class="bio-editor-wrap">
        <div class="bio-body"></div>
        <button type="button" class="bio-arrow bio-prev"><i class="fas fa-chevron-left"></i></button>
        <button type="button" class="bio-arrow bio-next"><i class="fas fa-chevron-right"></i></button>
        <span class="bio-page-num"></span>
      </div>
    </div>
    <div class="bio-section" data-bio-field="notes">
      <h3>Notes</h3>
      <div class="bio-editor-wrap">
        <div class="bio-body"></div>
        <button type="button" class="bio-arrow bio-prev"><i class="fas fa-chevron-left"></i></button>
        <button type="button" class="bio-arrow bio-next"><i class="fas fa-chevron-right"></i></button>
        <span class="bio-page-num"></span>
      </div>
    </div>
  </div>

  {{!-- COMBAT --}}
  <div class="tab combat" data-group="primary" data-tab="combat">
    <div class="section-block">
      <div class="combat-attack-header">
        <h2>Available Attacks <a class="attack-create" title="Create attack or maneuver"><i class="fas fa-plus"></i></a></h2>
        <button type="button" class="targeting-toggle {{#if targetingEnabled}}active{{/if}}" title="Toggle targeted attacks">
          <i class="fas fa-bullseye"></i>
          <span>Targeting</span>
        </button>
      </div>
      <div class="attack-list">
        {{#each attacks}}
        <div class="attack-row" data-attack-id="{{this.id}}">
          {{#if this.img}}<img class="attack-img" src="{{this.img}}" />
          {{else}}<span class="attack-icon"><i class="fas {{this.icon}}"></i></span>{{/if}}
          <span class="attack-name">{{this.name}}</span>
          <span class="attack-stat">{{this.pool}}</span>
          <span class="attack-dmg">Dmg: {{this.damage}} {{this.damageType}}</span>
          {{#if this.difficultyLabel}}<span class="attack-range">Difficulty: {{this.difficultyLabel}}</span>{{/if}}
          {{#if this.range}}<span class="attack-range">Range: {{this.range}} yds</span>{{/if}}
          {{#if this.ammoLabel}}<span class="attack-range">Ammo: {{this.ammoLabel}}</span>{{/if}}
          {{#if this.rate}}<span class="attack-range">Rate: {{this.rate}}</span>{{/if}}
          <button type="button" class="attack-btn" data-attack-id="{{this.id}}">
            <i class="fas fa-crosshairs"></i> Attack
          </button>
          {{#if this.isRanged}}
          <button type="button" class="attack-btn reload-btn" data-attack-id="{{this.id}}">
            <i class="fas fa-rotate-right"></i> Reload
          </button>
          {{/if}}
          {{#if this.custom}}
          <button type="button" class="attack-delete" data-custom-id="{{this.customId}}" title="Delete maneuver">
            <i class="fas fa-trash"></i>
          </button>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>
    <div class="combat-help">
      Target a token, then click Attack. If the attack hits, the defender can choose how to react from the chat.
    </div>
  </div>

  {{!-- INVENTORY --}}
  <div class="tab inventory" data-group="primary" data-tab="inventory">
    {{#if armorPenalty}}
    <div class="armor-penalty-banner">
      <i class="fas fa-shield-alt"></i> Armor Dex Penalty: {{armorPenalty}}
    </div>
    {{/if}}
    <div class="inventory-columns">
      <div class="inventory-column">
        <h3>Weapons <a class="item-create" data-type="weapon"><i class="fas fa-plus"></i></a></h3>
        <div class="item-list compact">
          {{#each weapons}}
          <div class="item {{#unless this.system.equipped}}stowed{{/unless}} {{#if this.reqUnmet}}req-unmet{{/if}}" data-item-id="{{this._id}}">
            <a class="item-equip {{#if this.system.equipped}}equipped{{/if}}" title="{{#if this.system.equipped}}Unequip{{else}}Equip{{/if}}">
              <i class="{{#if this.system.equipped}}fas fa-check-square{{else}}far fa-square{{/if}}"></i>
            </a>
            <span class="item-name">{{this.name}}</span>
            <span class="item-detail">{{this.system.damage}} {{this.system.damageType}}</span>
            {{#if this.system.range}}<span class="item-detail">Range: {{this.system.range}} yds</span>{{/if}}
            {{#if this.system.capacity}}<span class="item-detail">Cap: {{this.system.capacity}}</span>{{/if}}
            {{#if this.ammoLabel}}<span class="item-detail">Ammo: {{this.ammoLabel}}</span>{{/if}}
            {{#if this.system.rate}}<span class="item-detail">Rate: {{this.system.rate}}</span>{{/if}}
            {{#if this.reqLabel}}<span class="item-req {{#if this.reqUnmet}}unmet{{/if}}" title="Requires {{this.reqLabel}}"><i class="fas fa-lock"></i> {{this.reqLabel}}</span>{{/if}}
            <div class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
      <div class="inventory-column">
        <h3>Attire <a class="item-create" data-type="armor"><i class="fas fa-plus"></i></a></h3>
        <div class="item-list compact">
          {{#each armor}}
          <div class="item" data-item-id="{{this._id}}">
            <a class="item-equip {{#if this.system.equipped}}equipped{{/if}}" title="{{#if this.system.equipped}}Unequip{{else}}Equip{{/if}}">
              <i class="{{#if this.system.equipped}}fas fa-check-square{{else}}far fa-square{{/if}}"></i>
            </a>
            <span class="item-name">{{this.name}}</span>
            <span class="item-detail">Rating {{this.system.rating}}</span>
            {{#if this.system.penalty}}<span class="item-detail penalty">Pen {{this.system.penalty}}</span>{{/if}}
            <div class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
      <div class="inventory-column">
        <h3>Equipment <a class="item-create" data-type="equipment"><i class="fas fa-plus"></i></a></h3>
        <div class="item-list compact">
          {{#each equipment}}
          <div class="item" data-item-id="{{this._id}}">
            <a class="item-equip {{#if this.system.equipped}}equipped{{/if}}" title="{{#if this.system.equipped}}Unequip{{else}}Equip{{/if}}">
              <i class="{{#if this.system.equipped}}fas fa-check-square{{else}}far fa-square{{/if}}"></i>
            </a>
            <span class="item-name">{{this.name}}</span>
            {{#if (gt this.system.quantity 1)}}<span class="item-qty">x{{this.system.quantity}}</span>{{/if}}
            <div class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          {{/each}}
        </div>

        <h3>Containers <a class="item-create" data-type="container"><i class="fas fa-plus"></i></a></h3>
        <div class="item-list compact">
          {{#each containers}}
          <div class="item" data-item-id="{{this._id}}">
            <a class="item-equip {{#if this.system.equipped}}equipped{{/if}}" title="{{#if this.system.equipped}}Unequip{{else}}Equip{{/if}}">
              <i class="{{#if this.system.equipped}}fas fa-check-square{{else}}far fa-square{{/if}}"></i>
            </a>
            <span class="item-name">{{this.name}}</span>
            <span class="item-detail">Cap: {{this.system.capacity}}</span>
            {{#if this.system.penalty}}<span class="item-detail penalty">Pen {{this.system.penalty}}</span>{{/if}}
            <div class="item-controls">
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </div>
  </div>

</section>

</div>{{!-- .sheet-inner --}}
{{/if}}
